{
  "name": "codex-home-manager",
  "version": "1.0.3",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 5173",
    "serve": "python -m backend.server",
    "test:backend": "python -m pytest tests",
    "test": "npm run build && npm run test:backend",
    "gate": "python scripts/quality_gate.py",
    "package:connector": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-local-connector.ps1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sql.js": "^1.14.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.60.0",
    "ws": "^8.21.0"
  }
}
